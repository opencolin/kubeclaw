{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "KubeClaw",
  "description": "Deploy OpenClaw and NemoClaw on Nebius Managed Kubernetes",
  "colors": {
    "primary": "#0D9373",
    "light": "#55D799",
    "dark": "#0D9373"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "docs/quick-start",
              "docs/prerequisites",
              "docs/deployment-guide"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "docs/gpu-configuration",
              "docs/monitoring-setup",
              "docs/security-hardening"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "docs/architecture",
              "docs/troubleshooting",
              "docs/faq"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/opencolin/kubeclaw",
          "icon": "github"
        },
        {
          "anchor": "Nebius Docs",
          "href": "https://docs.nebius.cloud/en/docs/managed-kubernetes/",
          "icon": "book"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/opencolin/kubeclaw"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Deploy",
      "href": "https://github.com/opencolin/kubeclaw#quick-start-5-minutes"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/opencolin/kubeclaw"
    }
  }
}
